{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Bot (tsx watch)",
      "runtimeExecutable": "tsx",
      "runtimeArgs": ["watch"],
      "program": "${workspaceFolder}/index.ts",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Bot (single run)",
      "runtimeExecutable": "tsx",
      "program": "${workspaceFolder}/index.ts",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
